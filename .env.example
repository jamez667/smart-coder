# Copy this file to `.env` and fill in your own values. `.env` is gitignored and
# must never be committed. Loaded at startup by sc_model::load_dotenv.
#
# Only needed if you route a pipeline stage (coder / planner / advisor) to
# Gemini — a purely local llama.cpp/Ollama setup needs none of this. See the
# README section "Using Gemini as the planner".

# API key for Google's Gemini OpenAI-compatible endpoint. Lights up any stage
# routed to a Gemini connection without pasting the key into the GUI.
GEMINI_API_KEY=

# Optional: Google Cloud project id, if your Gemini access requires it.
GEMINI_PROJECT_ID=
