/target
**/*.rs.bk
Cargo.lock

# Workflow plan artifacts written by `smart-coder plan` (spec 09) — run output,
# not source.
.smart-coder/

# Stray stdout/stderr redirect logs from launching the GUI during dev.
sc-win-launch-*.log
.dc/

# Tailscale TLS cert/key (local, never commit)
*.ts.net.crt
*.ts.net.key

# Rust->Android native build output (regenerable from crates/sc-android)
**/jniLibs/**/*.so
