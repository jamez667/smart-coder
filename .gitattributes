# Normalize line endings so the repo behaves the same on every platform.
# Without this, a Windows contributor commits CRLF into shell scripts, which
# then fail under `sh` on Linux/CI (a `\r` sneaks into every line). Git stores
# text as LF and checks it out per-platform; the explicit rules below force LF
# for files that MUST stay LF regardless of the checkout OS.

# Let Git decide text vs binary by default, normalizing to LF in the repo.
* text=auto eol=lf

# Files that are executed by a POSIX shell / interpreter — always LF, even on a
# Windows checkout, or they break when run on Linux.
*.sh    text eol=lf
*.bash  text eol=lf
gradlew text eol=lf

# Windows-only scripts — keep CRLF so they behave in cmd/PowerShell.
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary assets — never touch.
*.png   binary
*.ico   binary
*.jar   binary
*.so    binary
